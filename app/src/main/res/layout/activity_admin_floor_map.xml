<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sơ Đồ Bàn"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_table_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 trống"
            android:textColor="@color/white"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Chú thích màu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="10dp"
        android:gravity="center">

        <View android:layout_width="14dp" android:layout_height="14dp"
            android:background="@color/table_empty" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Trống" android:textSize="12sp" android:layout_marginEnd="16dp"/>

        <View android:layout_width="14dp" android:layout_height="14dp"
            android:background="@color/table_occupied" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Có khách" android:textSize="12sp" android:layout_marginEnd="16dp"/>

        <View android:layout_width="14dp" android:layout_height="14dp"
            android:background="@color/table_waiting_payment" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chờ thanh toán" android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  💡 Nhấn bàn để xem chi tiết / xác nhận đơn / thanh toán"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:background="@color/background_light"
        android:padding="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <GridLayout
            android:id="@+id/grid_admin_tables"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:padding="12dp"/>
    </ScrollView>
</LinearLayout>

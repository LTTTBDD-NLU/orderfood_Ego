<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_back_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giỏ Hàng"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_cart_count_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 món"
            android:textColor="@color/white"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Thông tin bàn -->
    <TextView
        android:id="@+id/tv_cart_table"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đặt cho: Bàn --"
        android:background="@color/colorAccent"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:padding="10dp"
        android:paddingStart="16dp"/>

    <!-- Ô nhập số bàn — CHỈ HIỆN VỚI GUEST -->
    <LinearLayout
        android:id="@+id/layout_guest_table"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Số bàn: "
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/et_guest_table"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textSize="20sp"
            android:gravity="center"
            android:hint="--"
            android:padding="8dp"
            android:background="@color/background_light"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" (bắt buộc — nhân viên sẽ xác nhận)"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"/>
    </LinearLayout>

    <!-- Danh sách món -->
    <ListView
        android:id="@+id/lv_cart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="6dp"
        android:padding="8dp"/>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="8dp">

        <!-- Tiết kiệm (chỉ hiện với member) -->
        <LinearLayout
            android:id="@+id/layout_savings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💚 Tiết kiệm được:"
                android:textSize="13sp"
                android:textColor="#4CAF50"/>
            <TextView
                android:id="@+id/tv_savings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đ"
                android:textSize="13sp"
                android:textColor="#4CAF50"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng tiền:"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đ"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_confirm_order"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="XÁC NHẬN ĐẶT MÓN"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:padding="16dp"/>
    </LinearLayout>
</LinearLayout>

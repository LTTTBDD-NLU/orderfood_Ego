<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Logo + Tên trung tâm -->
    <LinearLayout
        android:id="@+id/layout_center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:padding="32dp">

        <!-- Icon dao & muỗng (text emoji thay thế) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍴"
            android:textSize="72sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EGO"
            android:textSize="56sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vitality Restaurant"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:letterSpacing="0.15"
            android:layout_marginBottom="48dp"/>

        <Button
            android:id="@+id/btn_guest_order"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VÀO XEM THỰC ĐƠN (KHÁCH)"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:padding="18dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_go_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ĐĂNG NHẬP (NHÂN VIÊN / THÀNH VIÊN)"
            android:backgroundTint="@color/background_light"
            android:textColor="@color/colorPrimary"
            android:textSize="13sp"
            android:padding="16dp"/>
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© 2025 EGO Vitality Restaurant"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="16dp"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>

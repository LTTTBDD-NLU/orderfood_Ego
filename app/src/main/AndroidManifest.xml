<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ego.restaurant">


    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- LAUNCHER -->
        <activity android:name=".activities.LandingActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Nhóm 1: Auth -->
        <activity android:name=".activities.LoginActivity" />
        <activity android:name=".activities.RegisterActivity" />
        <activity android:name=".activities.ChangePasswordActivity" />
        <activity android:name=".activities.ForceLogoutActivity" android:noHistory="true" />

        <!-- Nhóm 2-3: Khách & Member -->
        <activity android:name=".activities.CustomerActivity" />
        <activity android:name=".activities.MenuActivity" />
        <activity android:name=".activities.CartActivity" />
        <activity android:name=".activities.WaitingConfirmActivity" />
        <activity android:name=".activities.OrderTrackingActivity" />
        <activity android:name=".activities.BillPreviewActivity" />

        <!-- Nhóm 4: Phục vụ -->
        <activity android:name=".activities.WaiterActivity" />

        <!-- Nhóm 5: Bếp -->
        <activity android:name=".activities.KitchenActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".activities.KitchenHistoryActivity" />

        <!-- Nhóm 6: Nhân sự -->
        <activity android:name=".activities.AdminStaffActivity" />
        <activity android:name=".activities.AdminDashboardActivity" />
        <activity android:name=".activities.AdminFloorMapActivity" />
        <activity android:name=".activities.StaffProfileActivity" />
        <activity android:name=".activities.ScheduleActivity" />

        <!-- Nhóm 7: Thực đơn & Báo cáo -->
        <activity android:name=".activities.MenuManagementActivity" />
        <activity android:name=".activities.AddEditMenuItemActivity" />
        <activity android:name=".activities.AnalyticsActivity" />
        <activity android:name=".activities.PromotionActivity" />

    </application>

</manifest>

<?xml version="1.0" encoding="utf-8"?>
<!-- Màn hình 28: Hồ sơ & Tiền công -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hồ sơ nhân viên"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Avatar + Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="20dp"
                android:elevation="4dp"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@color/colorAccent"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:scaleType="centerInside"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_staff_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nguyễn Văn A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tv_staff_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phục vụ"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:background="@color/colorPrimary"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Thống kê -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/white" android:padding="16dp"
                    android:elevation="4dp" android:gravity="center" android:layout_marginEnd="6dp">
                    <TextView android:id="@+id/tv_total_days"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="24sp" android:textStyle="bold"
                        android:textColor="@color/colorPrimary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ngày công" android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/white" android:padding="16dp"
                    android:elevation="4dp" android:gravity="center">
                    <TextView android:id="@+id/tv_total_salary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0đ" android:textSize="18sp" android:textStyle="bold"
                        android:textColor="#4CAF50"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Thu nhập tạm tính" android:textSize="11sp"
                        android:textColor="@color/text_secondary" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Lịch sử ca làm -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lịch sử ca làm"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <ListView
                android:id="@+id/lv_shift_history"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:divider="@android:color/transparent"
                android:dividerHeight="4dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!-- Màn hình 26: Cấu hình Khuyến mãi -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/colorPrimary"
        android:padding="16dp" android:gravity="center_vertical">
        <TextView android:id="@+id/tv_back"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="←" android:textColor="@color/white"
            android:textSize="20sp" android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Cấu hình Khuyến mãi"
            android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn_add_promotion"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="+ Tạo mới" android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white" android:textSize="12sp"/>
    </LinearLayout>

    <ListView android:id="@+id/lv_promotions"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:divider="@android:color/transparent"
        android:dividerHeight="6dp" android:padding="8dp"/>
</LinearLayout>

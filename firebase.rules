{
  "rules": {
    "Users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "Tables": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "Menu_Items": {
      ".read": true,
      ".write": "auth != null"
    },
    "Orders": {
      ".read": true,
      ".write": true
    },
    "Revenue": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "Promotions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "Schedules": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
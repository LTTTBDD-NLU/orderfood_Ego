<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="14dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EGO — Phục Vụ"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_waiter_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng xuất"
            android:backgroundTint="@color/colorPrimaryDark"
            android:textColor="@color/white"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- NỘI DUNG 4 TAB — chỉ 1 cái hiển thị cùng lúc -->

    <!-- TAB 1: SƠ ĐỒ BÀN -->
    <LinearLayout
        android:id="@+id/tab_content_tables"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Chú thích màu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:padding="8dp"
            android:gravity="center">
            <View android:layout_width="14dp" android:layout_height="14dp"
                android:background="@color/table_empty" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Trống" android:textSize="11sp" android:layout_marginEnd="12dp"/>
            <View android:layout_width="14dp" android:layout_height="14dp"
                android:background="@color/table_occupied" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Có khách" android:textSize="11sp" android:layout_marginEnd="12dp"/>
            <View android:layout_width="14dp" android:layout_height="14dp"
                android:background="@color/table_waiting_payment" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Chờ TT" android:textSize="11sp"/>
        </LinearLayout>

        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <GridLayout
                android:id="@+id/grid_tables"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:padding="10dp"/>
        </ScrollView>
    </LinearLayout>

    <!-- TAB 2: MÓN ĐANG GIAO (DELIVERING) -->
    <LinearLayout
        android:id="@+id/tab_content_food"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  🚀 Món bếp đã xong — cần mang lên bàn"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@color/colorAccent"
            android:padding="10dp"/>

        <ListView
            android:id="@+id/lv_delivering_orders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- TAB 3: XÁC NHẬN BÀN (PENDING) -->
    <LinearLayout
        android:id="@+id/tab_content_confirm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  ⏳ Đơn chờ xác nhận bàn"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@color/status_pending"
            android:padding="10dp"/>

        <ListView
            android:id="@+id/lv_pending_orders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- TAB 4: PROFILE -->
    <ScrollView
        android:id="@+id/tab_content_profile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="20dp"
                android:elevation="4dp"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhân viên"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tv_profile_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phục vụ"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:background="@color/colorPrimary"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/white" android:padding="16dp"
                    android:elevation="4dp" android:gravity="center" android:layout_marginEnd="6dp">
                    <TextView android:id="@+id/tv_profile_days"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="24sp" android:textStyle="bold"
                        android:textColor="@color/colorPrimary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ngày công" android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/white" android:padding="16dp"
                    android:elevation="4dp" android:gravity="center">
                    <TextView android:id="@+id/tv_profile_salary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0đ" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="#4CAF50"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Thu nhập tạm tính" android:textSize="11sp"
                        android:textColor="@color/text_secondary" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Lịch làm việc của tôi -->
            <Button
                android:id="@+id/btn_my_schedule_from_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📅  XEM LỊCH LÀM VIỆC CỦA TÔI"
                android:backgroundTint="@color/colorAccent"
                android:textColor="@color/white"
                android:padding="14dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btn_change_password_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔑  ĐỔI MẬT KHẨU"
                android:backgroundTint="@color/background_light"
                android:textColor="#212121"
                android:padding="14dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp">

        <!-- Tab Bàn -->
        <LinearLayout
            android:id="@+id/tab_btn_tables"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/colorPrimary">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗺" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bàn" android:textSize="11sp" android:textColor="@color/white"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Tab Món ăn -->
        <LinearLayout
            android:id="@+id/tab_btn_food"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🍽" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Món ăn" android:textSize="11sp" android:textColor="#757575"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Tab Xác nhận -->
        <LinearLayout
            android:id="@+id/tab_btn_confirm"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅" android:textSize="20sp" android:gravity="center"/>
            <TextView
                android:id="@+id/tv_pending_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xác nhận" android:textSize="11sp" android:textColor="#757575"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Tab Profile -->
        <LinearLayout
            android:id="@+id/tab_btn_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textSize="11sp" android:textColor="#757575"
                android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorPrimary"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EGO Restaurant"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xin chào, Quý khách!"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tv_role_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KHÁCH VÃN LAI"
            android:textSize="11sp"
            android:textColor="@color/colorPrimary"
            android:background="@color/white"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Nội dung chính -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn đang ngồi bàn số mấy?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhân viên sẽ xác nhận bàn sau khi bạn đặt món"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_table_number"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:hint="Số bàn"
            android:inputType="number"
            android:textSize="32sp"
            android:gravity="center"
            android:padding="14dp"
            android:background="@color/white"
            android:elevation="4dp"
            android:layout_marginBottom="28dp"/>

        <Button
            android:id="@+id/btn_view_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="XEM THỰC ĐƠN &amp; ĐẶT MÓN"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="18dp"
            android:layout_marginBottom="10dp"/>

        <!-- Nút xem hóa đơn - chỉ Member -->
        <Button
            android:id="@+id/btn_my_bill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📄  XEM HÓA ĐƠN / THEO DÕI ĐƠN HÀNG"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_switch_account"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đăng nhập / Tạo tài khoản"
            android:textColor="@color/colorPrimary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tv_change_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đổi mật khẩu"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>

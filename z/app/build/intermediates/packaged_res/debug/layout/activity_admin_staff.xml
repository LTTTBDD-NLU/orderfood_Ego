<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_back_dashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quản Lý Nhân Sự"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_admin_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng xuất"
            android:backgroundTint="@color/colorPrimaryDark"
            android:textColor="@color/white"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Form thêm nhân viên mới -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm nhân viên mới"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_staff_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Họ và tên nhân viên"
            android:inputType="textPersonName"
            android:padding="10dp"
            android:background="@android:color/transparent"
            android:layout_marginBottom="2dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/text_secondary" android:layout_marginBottom="8dp"/>

        <!-- Dropdown vai trò bằng Spinner ẩn, dùng 3 nút chọn nhanh -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vai trò:"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button android:id="@+id/btn_role_waiter"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Phục vụ"
                android:backgroundTint="@color/background_light"
                android:textColor="#212121" android:textSize="12sp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btn_role_kitchen"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Bếp"
                android:backgroundTint="@color/background_light"
                android:textColor="#212121" android:textSize="12sp"
                android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btn_role_admin"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Quản lý"
                android:backgroundTint="@color/background_light"
                android:textColor="#212121" android:textSize="12sp"/>
        </LinearLayout>

        <!-- Ô ẩn lưu role đã chọn -->
        <EditText
            android:id="@+id/et_staff_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vai trò đã chọn"
            android:enabled="false"
            android:padding="8dp"
            android:background="@color/background_light"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_add_staff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THÊM NHÂN VIÊN"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:padding="12dp"/>
    </LinearLayout>

    <!-- Tiêu đề danh sách -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  Danh sách nhân viên (nhấn giữ để khóa/mở khóa)"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:background="@color/colorAccent"
        android:padding="10dp"
        android:layout_marginTop="8dp"/>

    <!-- ListView danh sách nhân viên -->
    <ListView
        android:id="@+id/lv_staff"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:padding="4dp"/>

</LinearLayout>

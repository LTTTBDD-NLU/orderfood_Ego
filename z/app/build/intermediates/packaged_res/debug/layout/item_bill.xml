<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/white"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:elevation="2dp">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_item_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tên món" android:textSize="14sp" android:textColor="#212121"/>
        <TextView android:id="@+id/tv_item_qty"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="x1" android:textSize="12sp" android:textColor="@color/text_secondary"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_item_total"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="0 đ" android:textSize="14sp" android:textStyle="bold"
        android:textColor="@color/colorPrimary"/>
</LinearLayout>

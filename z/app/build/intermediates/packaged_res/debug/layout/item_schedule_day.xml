<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="10dp"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tv_day_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thứ 2 - 01/01"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cb_morning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sáng\n07-12h"
            android:textSize="12sp"/>

        <CheckBox
            android:id="@+id/cb_afternoon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chiều\n12-17h"
            android:textSize="12sp"/>

        <CheckBox
            android:id="@+id/cb_evening"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tối\n17-22h"
            android:textSize="12sp"/>

        <!-- Chỉ quản lý thấy nút này -->
        <Button
            android:id="@+id/btn_attendance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chấm công"
            android:textSize="11sp"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:padding="6dp"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>

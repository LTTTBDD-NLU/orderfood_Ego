<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lịch làm việc"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_confirm_schedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chốt lịch"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Spinner chọn nhân viên - CHỈ HIỆN VỚI QUẢN LÝ -->
    <TextView
        android:id="@+id/tv_pick_staff_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  Chọn nhân viên để xem / chấm công:"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:background="@color/colorAccent"
        android:padding="8dp"
        android:visibility="gone"/>

    <Spinner
        android:id="@+id/spinner_staff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="8dp"
        android:visibility="gone"/>

    <!-- Chọn tuần -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_prev_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀"
            android:textSize="18sp"
            android:textColor="@color/colorPrimary"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tv_week_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tuần này"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_next_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="18sp"
            android:textColor="@color/colorPrimary"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Danh sách ngày -->
    <ListView
        android:id="@+id/lv_schedule"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:padding="6dp"/>

    <!-- Nút xin đổi ca - CHỈ HIỆN VỚI NHÂN VIÊN THƯỜNG -->
    <Button
        android:id="@+id/btn_request_shift_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📅  XIN ĐỔI CA"
        android:backgroundTint="@color/colorAccent"
        android:textColor="@color/white"
        android:padding="14dp"
        android:layout_margin="10dp"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_tracking_table"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Theo dõi đơn hàng"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Banner trạng thái tổng -->
    <TextView
        android:id="@+id/tv_order_phase_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏳ Đang chờ nhân viên xác nhận bàn..."
        android:textSize="14sp"
        android:textColor="@color/white"
        android:background="@color/status_pending"
        android:padding="12dp"
        android:gravity="center"
        android:textStyle="bold"/>

    <!-- Tóm tắt -->
    <TextView
        android:id="@+id/tv_status_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đang tải..."
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:background="@color/white"
        android:padding="10dp"
        android:paddingStart="16dp"/>

    <!-- Danh sách món -->
    <ListView
        android:id="@+id/lv_order_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:padding="8dp"/>

    <!-- Nút bên dưới -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="12dp"
        android:elevation="6dp">

        <Button
            android:id="@+id/btn_order_more"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➕  GỌI THÊM MÓN"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_request_payment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💳  YÊU CẦU THANH TOÁN"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:padding="12dp"/>
    </LinearLayout>
</LinearLayout>
